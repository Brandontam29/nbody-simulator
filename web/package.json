{
    "name": "nbody-simulator",
    "version": "1.0.0",
    "description": "NBody simulator on a HTML canvas where all calculation are performed via WASM Rust.",
    "type": "module",
    "scripts": {
        "wasm:build": "wasm-pack build ../nbody_simulator/ --target web && mkdir -p ./src/wasm/ && cp -r ../nbody_simulator/pkg/* ./src/wasm/",
        "wasm:watch": "cargo watch -w ../nbody_simulator/src/ -s 'npm run wasm:build'",
        "dev": "npm-run-all --parallel dev:vite wasm:watch",
        "dev:vite": "vite",
        "build": "npm run wasm:build && vite build",
        "preview": "vite preview"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@stylistic/eslint-plugin-js": "^1.6.3",
        "autoprefixer": "^10.4.27",
        "eslint": "^8.57.0",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.5.8",
        "tailwindcss": "^3.4.19",
        "vite": "^7.3.1",
        "vite-plugin-top-level-await": "^1.6.0",
        "vite-plugin-wasm": "^3.5.0"
    }
}
