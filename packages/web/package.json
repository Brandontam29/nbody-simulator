{
    "name": "@nbody/web",
    "version": "1.0.0",
    "description": "NBody simulator on a HTML canvas where all calculation are performed via WASM Rust.",
    "type": "module",
    "scripts": {
        "wasm:build": "wasm-pack build ../simulator/ --target web --out-dir $(pwd)/src/features/simulation/wasm",
        "wasm:watch": "nodemon --watch ../simulator/src/ -e rs --exec 'npm run wasm:build'",
        "dev": "npm-run-all --parallel dev:vite wasm:watch",
        "dev:vite": "vite",
        "build": "npm run wasm:build && npm run build:vite",
        "build:vite": "vite build",
        "preview": "vite preview",
        "lint": "oxlint .",
        "lint:fix": "oxlint . --fix"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.1",
        "nodemon": "^3.1.14",
        "npm-run-all": "^4.1.5",
        "oxlint": "^1.51.0",
        "tailwindcss": "^4.2.1",
        "vite": "^7.3.1",
        "vite-plugin-top-level-await": "^1.6.0",
        "vite-plugin-wasm": "^3.5.0"
    }
}
