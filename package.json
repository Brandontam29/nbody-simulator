{
  "name": "nbody-simulator-monorepo",
  "private": true,
  "description": "NBody simulator monorepo combining Rust WASM and Vite frontend.",
  "scripts": {
    "wasm:build": "npm run wasm:build --workspace=@nbody/web",
    "wasm:watch": "npm run wasm:watch --workspace=@nbody/web",
    "web:dev": "npm run dev:vite --workspace=@nbody/web",
    "web:build": "npm run build:vite --workspace=@nbody/web",
    "web:lint": "npm run lint --workspace=@nbody/web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "dev": "npm-run-all --parallel wasm:watch web:dev",
    "build": "npm run wasm:build && npm run web:build"
  },
  "workspaces": [
    "packages/web"
  ],
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "3.8.1"
  }
}
